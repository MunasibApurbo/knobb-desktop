{
  "name": "knobb",
  "private": true,
  "version": "0.1.8",
  "description": "Knobb is a React/Vite music app with a custom UI, a direct music data layer, and Supabase-backed account and library features.",
  "author": "Munasib Apurbo",
  "license": "MIT",
  "type": "module",
  "main": "desktop/knobb/main.mjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:backup": "node scripts/dev-from-deploy-backup.mjs",
    "prebuild": "node scripts/prepare-youtube-protobuf-cjs.mjs",
    "build": "vite build",
    "build:backup": "node scripts/build-from-deploy-backup.mjs",
    "build:dev": "vite build --mode development",
    "desktop:app": "electron desktop/knobb/main.mjs",
    "desktop:app:dev": "node scripts/launch-desktop-app.mjs",
    "desktop:release": "node scripts/prepare-desktop-release.mjs",
    "desktop:release:patch": "node scripts/prepare-desktop-release.mjs --bump patch",
    "desktop:release:minor": "node scripts/prepare-desktop-release.mjs --bump minor",
    "desktop:release:major": "node scripts/prepare-desktop-release.mjs --bump major",
    "desktop:package": "npm run build && electron-builder --publish never",
    "desktop:package:mac": "npm run build && electron-builder --mac --publish never",
    "desktop:package:win": "npm run build && electron-builder --win --publish never",
    "desktop:publish": "npm run build && electron-builder --publish always",
    "deploy:check": "node scripts/launch-deploy-report.mjs",
    "discord:bridge": "node scripts/discord-presence-bridge.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "preflight": "node scripts/launch-preflight.mjs",
    "smoke:site": "node scripts/launch-smoke.mjs",
    "supabase:deploy": "node scripts/deploy-supabase.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@react-three/fiber": "^8.17.10",
    "@supabase/supabase-js": "^2.98.0",
    "@uimaxbai/am-lyrics": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dashjs": "^5.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.36.0",
    "gsap": "^3.14.2",
    "hls.js": "^1.6.15",
    "lenis": "^1.3.18",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.170.0",
    "youtubei.js": "^16.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.2.4"
  }
}
